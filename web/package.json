{
  "name": "5gpn-dns-console",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "5gpn-dns control console SPA (served by the daemon from DNS_WEB_DIR; shipped as the 5gpn-web release tarball)",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && node scripts/check-pwa.mjs",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "npx playwright test",
    "e2e:ci": "npm run build && npx playwright test",
    "e2e:update": "npm run build && npx playwright test --update-snapshots",
    "bundle:check": "node scripts/check-bundle.mjs"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@material-symbols/svg-400": "0.45.8",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.0",
    "clsx": "^2.1.1",
    "daisyui": "5.6.18",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "leaflet": "1.9.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-i18next": "^15.7.4",
    "react-router-dom": "^7.18.1",
    "subsetted-fonts": "^1.0.4",
    "tailwind-merge": "^3.6.0",
    "uqr": "^0.1.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "1.9.21",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-pwa": "^1.0.0",
    "vite-plugin-svgr": "5.2.0",
    "vitest": "^4.1.10"
  }
}
