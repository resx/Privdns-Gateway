<?xml version="1.0" encoding="UTF-8"?>
<!--
  PrivDNS Gateway — iOS / macOS DoH 描述文件模板
  把 {{DNS_HOSTNAME}} 替换成你的 DNS 域名, {{UUID1}}/{{UUID2}} 替换成生成的 UUID。
  (V3 阶段 pdg 将自动生成并提供下载链接; 现阶段可手工替换或用 `uuidgen`。)
  安装后: 设置 → 通用 → VPN 与设备管理 → 安装描述文件。
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>PayloadContent</key>
  <array>
    <dict>
      <key>DNSSettings</key>
      <dict>
        <key>DNSProtocol</key>
        <string>HTTPS</string>
        <key>ServerURL</key>
        <string>https://{{DNS_HOSTNAME}}:8443/dns-query</string>
      </dict>
      <key>PayloadType</key>
      <string>com.apple.dnsSettings.managed</string>
      <key>PayloadIdentifier</key>
      <string>com.privdns.gateway.doh.{{UUID1}}</string>
      <key>PayloadUUID</key>
      <string>{{UUID1}}</string>
      <key>PayloadDisplayName</key>
      <string>PrivDNS Gateway (DoH)</string>
      <key>PayloadVersion</key>
      <integer>1</integer>
    </dict>
  </array>
  <key>PayloadDisplayName</key>
  <string>PrivDNS Gateway</string>
  <key>PayloadIdentifier</key>
  <string>com.privdns.gateway.{{UUID2}}</string>
  <key>PayloadUUID</key>
  <string>{{UUID2}}</string>
  <key>PayloadType</key>
  <string>Configuration</string>
  <key>PayloadVersion</key>
  <integer>1</integer>
</dict>
</plist>
