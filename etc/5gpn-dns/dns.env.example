# 5gpn-dns persisted config shape — install.sh's TUI writes /etc/5gpn/dns.env.
# Caller environment variables are not an installer input.
# This is the SINGLE source of truth: install.sh writes it, and all sub-scripts
# (cert-renew.sh, renew-hook.sh, reload-rules.sh) read it. There are no separate
# .state files.
# 'systemctl reload 5gpn-dns' (SIGHUP) reloads ONLY the rule files under
# /etc/5gpn/rules/ + chnroute — NOT this file. A daemon knob changed here needs
# 'systemctl restart 5gpn-dns' (knobs are read once at startup); cert knobs need
# a re-run of install.sh. (The TLS certs themselves auto-reload on mtime.)

# --- Listener addresses ---
# DoT is the ONLY client-facing DNS transport (DoH/plain-:53 removed 2026-07-10).
# DNS_LISTEN_DEBUG is a loopback plain-UDP listener for on-box troubleshooting.
DNS_LISTEN_DOT=:853
DNS_LISTEN_DEBUG=127.0.0.1:5353
# Control-plane API + web console. Reached at
# https://console.<DNS_BASE_DOMAIN> via the mihomo :443 SNI split, which routes the
# raw TLS stream straight to this loopback port. The SPA and /ios/ are public;
# every /api/* request still requires the bearer token. The
# zash role certificate is shared with the mihomo controller; verified clients
# derive zash.<DNS_BASE_DOMAIN> for TLS identity and trust DNS_ZASH_CERT.
# This listener must remain loopback-only behind the SNI-split path.
DNS_LISTEN_API=127.0.0.1:443

# --- TLS certificates (ONE mode-specific certificate, THREE role dirs) ---
# Production uses exactly one Certbot lineage named DNS_BASE_DOMAIN. Cloudflare
# DNS-01 issues apex + wildcard; HTTP-01 issues only the exact console/zash/dot
# SANs. That one certificate is deployed to dot/ (DoT :853 + iOS profile
# signing), web/ (control console), and
# zash/ (zashboard panel + mihomo controller). Paths are written by install.sh
# after issuance and renew-hook.sh after renewal. The daemon hot-reloads on
# file-mtime change. All three role pairs are required explicitly.
DNS_CERT=/etc/5gpn/cert/dot/current/fullchain.pem
DNS_KEY=/etc/5gpn/cert/dot/current/privkey.pem
DNS_WEB_CERT=/etc/5gpn/cert/web/current/fullchain.pem
DNS_WEB_KEY=/etc/5gpn/cert/web/current/privkey.pem
# The zash role is the trust anchor for the shared zashboard panel + mihomo
# controller path.
DNS_ZASH_CERT=/etc/5gpn/cert/zash/current/fullchain.pem
DNS_ZASH_KEY=/etc/5gpn/cert/zash/current/privkey.pem

# --- Deployment identity + cert mode (read by install.sh / renew-hook.sh and
# the daemon). dot./console./zash. service names are derived from the one base.
# If the verified Mihomo controller client cannot be built, DNS keeps starting
# while Mihomo operations stay unavailable rather than falling back to plaintext. ---
DNS_BASE_DOMAIN=       # operator's apex; console./zash./dot.<base> are auto-derived
# install.sh always requires console.<base> to be externally usable for public
# bootstrap. In HTTP-01 mode, console/zash/dot must each have exactly one public
# A answer equal to DNS_PUBLIC_IP and no AAAA answer. The TUI displays these
# records and asks the operator to confirm them, then waits for that exact result
# through 1.1.1.1 before issuance; the renewal helper repeats the same gate.
# There is no caller-environment bypass.
DNS_PUBLIC_IP=        # public IPv4 identity and HTTP-01 A-record target; auto-detected at install,
                      # change later via '5gpn configure'
DNS_GATEWAY_IP=       # client-facing address; proxy/foreign names return this so
                      # mihomo (data plane, direct egress) intercepts + forwards them.
DNS_MIHOMO_LISTEN_IPS= # comma-separated LOCAL IPv4 addresses where fresh/reset seeds bind TCP :80/:443/:5060/:8080/:8443 and UDP :443/:5060;
                       # normally includes DNS_GATEWAY_IP, never a non-local NAT address
CERT_MODE=cloudflare  # cloudflare | http-01 | debug
# cloudflare: Let's Encrypt DNS-01 via Cloudflare, exact SANs <base> + *.<base>;
# no :80 handoff, and zash may remain synthetic.
# http-01: Let's Encrypt standalone challenge, exact SANs console/zash/dot only
# (no apex/wildcard); all three require the public A/no-AAAA gate above. Initial
# issuance and due renewal briefly stop and then restore mihomo to release :80.
# debug: self-signed test certificate; no Certbot renewal.
# Both production modes use only `--cert-name <DNS_BASE_DOMAIN>`. The systemd
# timer and confirmed Telegram bot action call the same mode-aware renewal helper.
CERT_EMAIL=           # Let's Encrypt registration email

# The Cloudflare API token is used only by CERT_MODE=cloudflare. It is entered
# only through the TUI and stored in /etc/5gpn/acme/cloudflare.ini (directory
# 0700, file 0600). It is never written here, accepted from caller environment,
# or logged. It remains mandatory for unattended renewal even when the current
# Cloudflare certificate is reusable. HTTP-01 and debug neither require nor
# weaken these token rules.

# --- Upstream resolvers ---
# China: the operational domestic resolver over plain UDP/53.
DNS_CHINA=223.5.5.5

# Trust: the operational resolver over plain UDP/53. Bare IP[:port] means plain
# UDP; the serverName@IP[:port] form remains available for explicit DoT config.
DNS_TRUST=22.22.22.22
# Web-managed overrides. If present, these files override the matching env
# defaults at startup; empty disables each override mechanism.
DNS_UPSTREAMS=/etc/5gpn/upstreams.json
DNS_ECS_FILE=/etc/5gpn/ecs.json

# China-group ECS operational default. A valid DNS_ECS_FILE override takes
# precedence at runtime; set this to "off" to disable the install-time value.
DNS_CHINA_ECS=112.96.32.0/24

# DNS 0x20 anti-spoof on the plaintext-UDP china group: randomly cases the
# outgoing query name and requires the reply to echo it, raising the bar for
# off-path cache poisoning of CN verdicts. Default ON (1) — a startup self-probe
# auto-disables it if a configured china upstream is found to normalise query-
# name case (which would otherwise funnel CN domains through the gateway), so
# default-on cannot degrade resolution. Set 0 to force it off.
DNS_CHINA_0X20=1

# --- Rule files ---
DNS_RULES_DIR=/etc/5gpn/rules

# Path to the chnroute IPv4 list (used for split-horizon routing).
DNS_CHNROUTE=/etc/5gpn/rules/china_ip_list.txt

# --- Remote rule-list subscriptions ---
# Path to subscriptions.json (fetched in-process; caches land in
# DNS_RULES_DIR/<category>/<name>.txt). install.sh seeds only the system chnroute
# subscription here. Operator policy subscriptions live in DNS_POLICY_RULES
# and are compiled into managed subscription entries during policy Apply:
#
# {
#   "version": 1,
#   "subscriptions": [
#     { "id": "china-ip", "category": "chnroute", "name": "china_ip_list",
#       "url": "https://raw.githubusercontent.com/17mon/china_ip_list/master/china_ip_list.txt",
#       "format": "cidr", "enabled": true, "interval": "24h" }
#   ]
# }
#
# Supported domain formats: plain | gfwlist | dnsmasq | hosts;
# chnroute uses cidr. Disable any entry (enabled:false) or edit via the Web/Bot
# console; a failed/too-small fetch keeps the prior cache (offline-safe).
DNS_SUBSCRIPTIONS=/etc/5gpn/subscriptions.json
DNS_POLICY_RULES=/etc/5gpn/policy.json

# --- Control-plane HTTPS API + web console ---
# Bearer token for the control-plane API on DNS_LISTEN_API. Empty disables the
# control plane (never served unauthenticated). install.sh auto-generates one
# on first install (openssl rand -hex 32) and preserves it across re-installs
# (never rotates a working token).
DNS_API_TOKEN=

# API per-source rate limit (token bucket, applied before auth); <=0 disables it.
DNS_API_RATE=20
DNS_API_BURST=40

# --- Mihomo data plane ---
# Mihomo's loopback external-controller API (DNS_MIHOMO_CONTROLLER) + its
# bearer secret (DNS_MIHOMO_SECRET) + the zashboard source-IP allowlist file
# (DNS_WHITELIST_FILE) mihomo's rule-provider reloads from. DNS_MIHOMO_CONTROLLER
# remains the loopback dial target; the verified controller derives
# zash.<DNS_BASE_DOMAIN> for TLS SNI/identity and trusts DNS_ZASH_CERT. Mihomo v1.19.28 also needs
# SAFE_PATHS=/etc/5gpn/cert/zash in its systemd unit because that shared cert
# lives outside -d /etc/5gpn/mihomo. Network access control for the zashboard
# panel lives HERE (mihomo whitelist.txt,
# TUI-managed via '5gpn add-allow <cidr>' / '5gpn del-allow <cidr>'), not
# in an in-process login-failure lockout. Ordinary reinstall and configure
# operations keep a valid operator-owned mihomo config byte-for-byte.
DNS_MIHOMO_CONTROLLER=127.0.0.1:9090
DNS_MIHOMO_SECRET=
DNS_WHITELIST_FILE=/etc/5gpn/mihomo/whitelist.txt

# --- Stats persistence ---
# Reason-level counters + observability metrics persisted here across restarts;
# empty = don't persist (counters start at zero each boot).
DNS_STATS_FILE=/etc/5gpn/stats.json

# --- iOS profile files + Telegram control bot ---
# WWW_DIR is the .mobileconfig directory the daemon serves at the web console's
# public console path (https://console.<base>/ios/ios-dot.mobileconfig).
# Telegram runs as an in-process 5gpn-dns component. TGBOT_TOKEN/TGBOT_ADMINS
# are startup/bootstrap defaults only. `5gpn setup-tgbot` and Web Settings use
# the authenticated live API to validate a token and atomically write the
# DNS_TGBOT_FILE override; once that file exists it is authoritative. The API
# never returns the token. TGBOT_ADMINS is a comma-separated list of positive
# numeric Telegram user IDs.
WWW_DIR=/opt/5gpn/www
TGBOT_TOKEN=
TGBOT_ADMINS=
DNS_TGBOT_FILE=/etc/5gpn/tgbot.json
# Optional Telegram-only HTTP/HTTPS CONNECT proxy URL, for example
# http://127.0.0.1:7890. This is read at daemon startup (restart after changing)
# and is deliberately not stored in tgbot.json. 5gpn never edits the fully
# operator-owned mihomo config to create or expose a proxy listener.
TGBOT_PROXY_URL=
# Opt-in protected private alerts to every configured admin when certificate,
# mihomo, or upstream health changes. This monitor runs inside 5gpn-dns and
# therefore cannot report its own process/host death; keep DNS_HEARTBEAT_URL for
# that external dead-man's-switch signal.
TGBOT_ALERTS=false

# --- Control-console SPA (served from disk by the loopback :443 server behind
# the mihomo SNI split) ---
# Directory install.sh extracts the 5gpn-web release tarball into. An unpopulated
# dir serves a built-in placeholder; the API works regardless.
DNS_WEB_DIR=/opt/5gpn/web

# --- zashboard panel (Zephyruso/zashboard, a mihomo/Clash web dashboard) ---
# Pinned dist.zip unpacked to DNS_ZASH_DIR, served as a SECOND loopback HTTPS
# listener on DNS_ZASH_LISTEN. Its /proxy/ path is a transparent controller
# proxy: zashboard presents DNS_MIHOMO_SECRET itself. The console does not get
# that broad capability; it uses bearer-protected health/config APIs and a
# short-lived one-use ticket for the read-only /proxy/logs WebSocket. Reached
# at https://zash.<DNS_BASE_DOMAIN> via the mihomo :443 SNI split, with the shared
# zash role certificate.
DNS_ZASH_DIR=/opt/5gpn/zash
DNS_ZASH_LISTEN=127.0.0.2:443

# --- Cache / performance ---
DNS_CACHE_SIZE=4096
DNS_TTL_MIN=300
DNS_TTL_MAX=86400
DNS_QUERY_TIMEOUT=5s

# --- Liveness heartbeat (dead-man's switch) ---
# When set, the daemon GETs this URL every DNS_HEARTBEAT_INTERVAL while alive; an
# external monitor (healthchecks.io, Uptime Kuma push endpoint, self-hosted)
# alerts when the pings STOP. This is the only signal that survives a box-down or
# crash-loop — the Telegram bot dies with the daemon, so it cannot report the
# box being gone. Empty disables.
DNS_HEARTBEAT_URL=
DNS_HEARTBEAT_INTERVAL=60s
# DNS_MAX_INFLIGHT: max concurrent in-flight resolutions (admission control);
# 0 disables shedding. Note: this is a GLOBAL cap, not per-source — there is no
# per-client fairness, so one runaway client can occupy the whole in-flight
# budget (all others get REFUSED) or thrash the shared cache.
DNS_MAX_INFLIGHT=4096

# DNS_EGRESS_BROKER: loopback resolver used by mihomo for sniffed origins.
# Active extensions select the China or trust group per capture host; every
# other hostname uses trust. Must be loopback IPv4 and cannot be empty.
DNS_EGRESS_BROKER=127.0.0.1:5354

# DNS_MIHOMO_CONFIG is the complete operator-owned mihomo configuration edited
# through the console's raw config page. Updates are validated with `mihomo -t`
# and hot-applied through the loopback controller.
DNS_MIHOMO_CONFIG=/etc/5gpn/mihomo/config.yaml
# Modular interception sidecar document. The console may update immutable module
# native extension snapshots and typed settings; SOCKS credentials and certificate paths are preserved.
DNS_INTERCEPT_CONFIG=/etc/5gpn/intercept/config.json
# Console-managed extension marketplace source snapshots. A missing file is an
# empty source list; successful source refreshes replace one complete cached
# index atomically and failed refreshes preserve the previous snapshot.
DNS_MARKETPLACES_FILE=/etc/5gpn/extension-marketplaces.json

# Mihomo/release versions and digests are fixed by the release installer; caller
# overrides are not supported. There is NO host firewall management — use your provider's security group
# if you need one; zashboard is gated by mihomo's whitelist.txt source-IP
# rule-provider (DNS_WHITELIST_FILE above), while console APIs require bearer auth.
# CERT_MODE is cloudflare (default, apex + wildcard DNS-01) | http-01 (three
# exact service SANs through standalone HTTP) | debug. Generic non-Cloudflare
# DNS-01 and certificate import remain unsupported.

# Invalid values for the numeric knobs above (cache/ttl/inflight/timeout) and
# the API rate/burst are non-fatal: 5gpn-dns logs a
# warning and falls back to the default rather than refusing to start — a single
# typo must never crash the network's only resolver into a restart loop.
