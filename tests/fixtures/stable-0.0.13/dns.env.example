# Source: 5gpn release 0.0.13, etc/5gpn-dns/dns.env.example.
# This frozen fixture keeps the complete 0.0.13 key set. Deployment-specific
# values use RFC 2606 and RFC 5737 examples so the fixture is safe in tests.

# Listener addresses.
DNS_LISTEN_DOT=:853
DNS_LISTEN_DEBUG=127.0.0.1:5353
DNS_LISTEN_API=127.0.0.1:443

# Certificate roles.
DNS_CERT=/etc/5gpn/cert/dot/current/fullchain.pem
DNS_KEY=/etc/5gpn/cert/dot/current/privkey.pem
DNS_WEB_CERT=/etc/5gpn/cert/web/current/fullchain.pem
DNS_WEB_KEY=/etc/5gpn/cert/web/current/privkey.pem
DNS_ZASH_CERT=/etc/5gpn/cert/zash/current/fullchain.pem
DNS_ZASH_KEY=/etc/5gpn/cert/zash/current/privkey.pem

# Deployment identity.
DNS_BASE_DOMAIN=example.com
DNS_PUBLIC_IP=192.0.2.10
DNS_GATEWAY_IP=192.0.2.10
DNS_MIHOMO_LISTEN_IPS=192.0.2.10
CERT_MODE=debug
CERT_EMAIL=

# Upstreams and policy files.
DNS_CHINA=192.0.2.53
DNS_TRUST=198.51.100.53
DNS_UPSTREAMS=/etc/5gpn/upstreams.json
DNS_ECS_FILE=/etc/5gpn/ecs.json
DNS_CHINA_ECS=192.0.2.0/24
DNS_CHINA_0X20=1
DNS_RULES_DIR=/etc/5gpn/rules
DNS_CHNROUTE=/etc/5gpn/rules/china_ip_list.txt
DNS_SUBSCRIPTIONS=/etc/5gpn/subscriptions.json
DNS_POLICY_RULES=/etc/5gpn/policy.json

# Control plane and mihomo.
DNS_API_TOKEN=fixture-api-token
DNS_API_RATE=20
DNS_API_BURST=40
DNS_MIHOMO_CONTROLLER=127.0.0.1:9090
DNS_MIHOMO_SECRET=fixture-controller-secret
DNS_WHITELIST_FILE=/etc/5gpn/mihomo/whitelist.txt
DNS_STATS_FILE=/etc/5gpn/stats.json

# iOS and Telegram.
WWW_DIR=/opt/5gpn/www
TGBOT_TOKEN=
TGBOT_ADMINS=
DNS_TGBOT_FILE=/etc/5gpn/tgbot.json
TGBOT_PROXY_URL=
TGBOT_ALERTS=false

# Web surfaces.
DNS_WEB_DIR=/opt/5gpn/web
DNS_ZASH_DIR=/opt/5gpn/zash
DNS_ZASH_LISTEN=127.0.0.2:443

# Runtime limits.
DNS_CACHE_SIZE=4096
DNS_TTL_MIN=300
DNS_TTL_MAX=86400
DNS_QUERY_TIMEOUT=5s
DNS_HEARTBEAT_URL=
DNS_HEARTBEAT_INTERVAL=60s
DNS_MAX_INFLIGHT=4096

# Egress DNS and operator-owned mihomo config.
DNS_EGRESS_BROKER=127.0.0.1:5354
DNS_MIHOMO_CONFIG=/etc/5gpn/mihomo/config.yaml
DNS_EGRESS_RESOLVER=203.0.113.53
